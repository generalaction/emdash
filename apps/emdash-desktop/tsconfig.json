{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "allowJs": false,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["react", "react-dom", "electron-vite/node", "node"],
    "paths": {
      "@renderer/*": ["./src/renderer/*"],
      "@main/*": ["./src/main/*"],
      "@shared/*": ["./src/shared/*"],
      "@emdash/core/acp": ["../../packages/core/src/acp/index.ts"],
      "@emdash/core/wire": ["../../packages/core/src/wire/index.ts"],
      "@root/*": ["./*"],
      "@/*": ["./src/*"],
      "@tooling/*": ["./tooling/*"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/renderer/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/types/**/*",
    "src/test/**/*",
    "tooling/**/*"
  ],
  "exclude": ["node_modules", "dist", "out", "**/_*/**"]
}
