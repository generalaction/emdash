{
  "name": "@emdash/emdash-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Private-network mobile client for Emdash",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:gateway": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/apps/emdash-mobile/src\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emdash/chat-ui": "workspace:*",
    "@emdash/core": "workspace:*",
    "@emdash/ui": "workspace:*",
    "@emdash/wire": "workspace:*",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.564.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^6.0.2",
    "vite": "7.1.11",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.28.0"
  },
  "packageManager": "pnpm@10.28.2",
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  }
}
