      "@emdash/core/primitives/*": ["../../packages/core/src/primitives/*"],
      "@emdash/core/workspace-server/*": ["../../packages/core/src/workspace-server/*"],
      "@runtimes/*": ["../../packages/core/src/runtimes/*"],
      "@services/*": ["../../packages/core/src/services/*"],
      "@primitives/*": ["../../packages/core/src/primitives/*"],
      "@workspace-server/*": ["../../packages/core/src/workspace-server/*"]
