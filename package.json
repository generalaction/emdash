{
  "name": "emdash-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @emdash/emdash-desktop run dev",
    "build": "pnpm --filter @emdash/emdash-desktop run build",
    "test": "pnpm --filter @emdash/emdash-desktop run test",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.28.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "electron",
      "esbuild",
      "node-pty",
      "protobufjs",
      "sqlite3"
    ],
    "ignoredBuiltDependencies": [
      "cpu-features",
      "ssh2"
    ]
  }
}
