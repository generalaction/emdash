{
  "name": "@emdash/chat-ui",
  "version": "1.0.0",
  "private": true,
  "description": "Solid-based chat transcript renderer with pretext layout engine",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.tsx",
    "./react": "./src/react/index.ts",
    "./chat-theme.css": "./src/chat-theme.css"
  },
  "scripts": {
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/chat-ui/src\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@emdash/ui": "workspace:*",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/cascadia-code": "^5.2.3",
    "@shikijs/langs": "^4.2.0",
    "@shikijs/themes": "^4.2.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "shiki": "^4.2.0",
    "solid-js": "^1.9.13",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.14",
    "@storybook/addon-docs": "^10.4.5",
    "@tailwindcss/vite": "^4.2.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.69.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.4.5",
    "storybook-solidjs-vite": "10.4.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "7.1.11",
    "vite-plugin-solid": "2.11.12",
    "vitest": "^3.2.6"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "pnpm@10.28.2"
}
