{
  "name": "@emdash/cli-agent-plugins",
  "version": "1.0.0",
  "description": "Plugin interfaces and helpers for CLI agent providers",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./metadata": {
      "types": "./dist/metadata.d.mts",
      "default": "./dist/metadata.mjs"
    },
    "./icons": {
      "types": "./dist/icons.d.mts",
      "default": "./dist/icons.mjs"
    },
    "./providers": {
      "types": "./dist/providers.d.mts",
      "default": "./dist/providers.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "smol-toml": "^1.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.69.0",
    "react": "^19.2.7",
    "tsdown": "^0.22.2",
    "vitest": "^3.1.4"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "packageManager": "pnpm@10.28.2"
}
