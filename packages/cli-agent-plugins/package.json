{
  "name": "cli-agent-plugins",
  "version": "1.0.0",
  "description": "Plugin interfaces and helpers for CLI agent providers",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./impl": {
      "import": {
        "types": "./dist/impl.d.mts",
        "default": "./dist/impl.mjs"
      },
      "require": {
        "types": "./dist/impl.d.cts",
        "default": "./dist/impl.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt --write"
  },
  "dependencies": {
    "smol-toml": "^1.6.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "react": "^19.2.7",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.28.2"
}
