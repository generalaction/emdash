{
  "name": "@emdash/core",
  "version": "1.0.0",
  "description": "Transport-agnostic core runtime primitives for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./acp": {
      "types": "./dist/acp.d.mts",
      "default": "./dist/acp.mjs"
    },
    "./acp/client": {
      "types": "./dist/acp-client.d.mts",
      "default": "./dist/acp-client.mjs"
    },
    "./acp/transcript-parser": {
      "types": "./dist/acp-transcript-parser.d.mts",
      "default": "./dist/acp-transcript-parser.mjs"
    },
    "./deps": {
      "types": "./dist/deps.d.mts",
      "default": "./dist/deps.mjs"
    },
    "./deps/runtime": {
      "types": "./dist/deps-runtime.d.mts",
      "default": "./dist/deps-runtime.mjs"
    },
    "./exec": {
      "types": "./dist/exec.d.mts",
      "default": "./dist/exec.mjs"
    },
    "./files": {
      "types": "./dist/files.d.mts",
      "default": "./dist/files.mjs"
    },
    "./watch": {
      "types": "./dist/watch.d.mts",
      "default": "./dist/watch.mjs"
    },
    "./git": {
      "types": "./dist/git.d.mts",
      "default": "./dist/git.mjs"
    },
    "./lib": {
      "types": "./dist/lib.d.mts",
      "default": "./dist/lib.mjs"
    },
    "./agents/plugins": {
      "types": "./dist/agents-plugins.d.mts",
      "default": "./dist/agents-plugins.mjs"
    },
    "./agents/plugins/helpers": {
      "types": "./dist/agents-plugins-helpers.d.mts",
      "default": "./dist/agents-plugins-helpers.mjs"
    },
    "./live": {
      "types": "./dist/live.d.mts",
      "default": "./dist/live.mjs"
    },
    "./wire": {
      "types": "./dist/wire.d.mts",
      "default": "./dist/wire.mjs"
    },
    "./workspace-server": {
      "types": "./dist/workspace-server.d.mts",
      "default": "./dist/workspace-server.mjs"
    },
    "./pty-conversations": {
      "types": "./dist/pty-conversations.d.mts",
      "default": "./dist/pty-conversations.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/core\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0",
    "@emdash/shared": "workspace:*",
    "@orpc/contract": "^1.14.6",
    "@orpc/server": "^1.14.6",
    "@parcel/watcher": "^2.5.6",
    "glob": "^13.0.6",
    "immer": "^10.1.1",
    "node-pty": "1.1.0",
    "semver": "^7.8.4",
    "smol-toml": "^1.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.0"
  }
}
