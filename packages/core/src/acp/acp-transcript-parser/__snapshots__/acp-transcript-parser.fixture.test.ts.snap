        {
          "id": "677167db-64b7-4193-8470-302e96b223a6:turn:11:message:user",
          "kind": "message",
          "role": "user",
          "streaming": false,
          "text": "Explain the ACP session lifecycle in detail, using markdown headings for each phase and including a fenced code block showing an example sequence of events.",
        },
        {
          "id": "677167db-64b7-4193-8470-302e96b223a6:turn:11:toolu_01AY8xD2Y4FtSd1YEV7FdL91",
          "kind": "tool",
          "name": "grep -rl "stopReason" /private/tmp/emdash-acp-fixture-1783037827823/packages/core/src/acp",
