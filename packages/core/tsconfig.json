{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@emdash/wire/api": ["../wire/src/api/index.ts"],
      "@emdash/wire/scheduling": ["../wire/src/scheduling/index.ts"],
      "@emdash/wire/testing": ["../wire/src/testing/index.ts"],
      "@emdash/wire/util": ["../wire/src/util/index.ts"],
      "@emdash/wire/worker": ["../wire/src/worker/index.ts"],
      "@emdash/wire/worker/node": ["../wire/src/worker/node/index.ts"],
      "@emdash/wire": ["../wire/src/index.ts"],
      "@runtimes/*": ["./src/runtimes/*"],
      "@services/*": ["./src/services/*"],
      "@primitives/*": ["./src/primitives/*"],
      "@workspace-server/*": ["./src/workspace-server/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
