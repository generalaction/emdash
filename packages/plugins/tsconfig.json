{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "paths": {
      "@emdash/core/runtimes/*": ["../core/src/runtimes/*"],
      "@emdash/core/services/*": ["../core/src/services/*"],
      "@emdash/core/primitives/*": ["../core/src/primitives/*"],
      "@emdash/core/workspace-server/*": ["../core/src/workspace-server/*"],
      "@runtimes/*": ["../core/src/runtimes/*"],
      "@services/*": ["../core/src/services/*"],
      "@primitives/*": ["../core/src/primitives/*"],
      "@workspace-server/*": ["../core/src/workspace-server/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tooling/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
