{
  "name": "@emdash/runtime",
  "version": "1.0.0",
  "description": "Host-scoped runtime implementations for Emdash domains",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./acp-agents": {
      "types": "./dist/acp-agents.d.mts",
      "default": "./dist/acp-agents.mjs"
    },
    "./acp-agents/node": {
      "types": "./dist/acp-agents-node.d.mts",
      "default": "./dist/acp-agents-node.mjs"
    },
    "./tui-agents": {
      "types": "./dist/tui-agents.d.mts",
      "default": "./dist/tui-agents.mjs"
    },
    "./tui-agents/node": {
      "types": "./dist/tui-agents-node.d.mts",
      "default": "./dist/tui-agents-node.mjs"
    },
    "./agent-config": {
      "types": "./dist/agent-config.d.mts",
      "default": "./dist/agent-config.mjs"
    },
    "./agent-config/node": {
      "types": "./dist/agent-config-node.d.mts",
      "default": "./dist/agent-config-node.mjs"
    },
    "./git": {
      "types": "./dist/git.d.mts",
      "default": "./dist/git.mjs"
    },
    "./git/node": {
      "types": "./dist/git-node.d.mts",
      "default": "./dist/git-node.mjs"
    },
    "./files": {
      "types": "./dist/files.d.mts",
      "default": "./dist/files.mjs"
    },
    "./files/node": {
      "types": "./dist/files-node.d.mts",
      "default": "./dist/files-node.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/runtime\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0",
    "@emdash/core": "workspace:*",
    "@emdash/shared": "workspace:*",
    "@emdash/wire": "workspace:*",
    "glob": "^13.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "node-pty": "1.1.0"
  },
  "peerDependenciesMeta": {
    "node-pty": {
      "optional": true
    }
  }
}
