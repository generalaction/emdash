{
  "name": "@emdash/shared",
  "version": "1.0.0",
  "description": "Shared primitives for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/shared\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.0"
  }
}
