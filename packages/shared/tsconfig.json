{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@emdash/shared/scheduling": ["./src/scheduling/index.ts"],
      "@emdash/shared/concurrency": ["./src/concurrency/index.ts"],
      "@emdash/shared/util": ["./src/util/index.ts"],
      "@emdash/shared/testing": ["./src/testing/index.ts"],
      "@emdash/shared/logger": ["./src/logger/index.ts"],
      "@emdash/shared/result": ["./src/result/index.ts"],
      "@emdash/shared": ["./src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
