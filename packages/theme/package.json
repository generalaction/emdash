{
  "name": "@emdash/theme",
  "version": "1.0.0",
  "description": "Theme generation and design token artifacts for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist",
    "src/__generated__"
  ],
  "type": "module",
  "sideEffects": [
    "./src/__generated__/theme.css",
    "./src/__generated__/semantic.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./manifest": {
      "types": "./dist/manifest.d.mts",
      "default": "./dist/manifest.mjs"
    },
    "./densities": {
      "types": "./dist/densities.d.mts",
      "default": "./dist/densities.mjs"
    },
    "./theme.css": "./src/__generated__/theme.css",
    "./semantic.css": "./src/__generated__/semantic.css",
    "./shiki-themes": {
      "types": "./dist/shiki-themes.d.mts",
      "default": "./dist/shiki-themes.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsx src/core/codegen/run.ts && oxfmt src/__generated__/theme.css src/__generated__/semantic.css && tsdown",
    "build:theme": "tsx src/core/codegen/run.ts && oxfmt src/__generated__/theme.css src/__generated__/semantic.css",
    "watch:theme": "tsx --watch src/core/codegen/run.ts",
    "test": "vitest run",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/theme/src\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "colorjs.io": "^0.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.28.2"
}
