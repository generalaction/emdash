{
  "name": "@emdash/ui",
  "version": "1.0.0",
  "description": "Shared UI components and theme system for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist",
    "src/theme"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/style.css"
  ],
  "exports": {
    "./primitives": {
      "types": "./dist/src/primitives/index.d.ts",
      "default": "./dist/primitives.js"
    },
    "./components": {
      "types": "./dist/src/components/index.d.ts",
      "default": "./dist/components.js"
    },
    "./patterns": {
      "types": "./dist/src/patterns/index.d.ts",
      "default": "./dist/patterns.js"
    },
    "./style.css": "./dist/style.css",
    "./theme/sprinkles": {
      "types": "./dist/src/theme/sprinkles.css.d.ts",
      "default": "./dist/theme/sprinkles.js"
    },
    "./theme/tokens.css": "./src/theme/tokens.css",
    "./theme/theme.css": "./src/theme/theme.css",
    "./theme/tailwind.css": "./src/theme/tailwind.css",
    "./theme/base.css": "./src/theme/theme.base.css",
    "./theme/semantic.css": "./src/theme/semantic.css",
    "./theme/surfaces.css": "./src/theme/surfaces.css",
    "./theme/effects.css": "./src/theme/effects.css",
    "./theme/overflow-fade.css": "./src/theme/overflow-fade.css",
    "./theme/typography.css": "./src/theme/typography.css",
    "./recipes/control": {
      "types": "./dist/src/recipes/control.d.ts",
      "default": "./dist/recipes/control.js"
    },
    "./recipes/input": {
      "types": "./dist/src/recipes/input.d.ts",
      "default": "./dist/recipes/input.js"
    },
    "./theme/tokens.js": "./src/theme/tokens.js",
    "./theme/tokens.d.ts": "./src/theme/tokens.d.ts",
    "./theme/shiki-themes": "./src/theme/themes/shiki-themes.ts",
    "./theme/manifest": "./src/theme/theme-manifest.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite build --config vite.lib.config.ts --watch",
    "build": "vite build --config vite.lib.config.ts",
    "test": "vitest run",
    "theme:build": "tsx src/theme/build.ts && oxfmt src/theme/theme.css src/theme/semantic.css src/theme/tokens.js",
    "theme:watch": "tsx --watch src/theme/build.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/ui/src\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-mention": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/suggestion": "^3.26.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0"
  },
  "devDependencies": {
    "@emdash/chat-ui": "workspace:*",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^20.19.42",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "colorjs.io": "^0.5.2",
    "devicon": "^2.17.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.4.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vite": "^7.1.11",
    "vite-plugin-dts": "5.0.2",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "packageManager": "pnpm@10.28.2"
}
