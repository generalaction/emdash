{
  "name": "@emdash/ui",
  "version": "1.0.0",
  "description": "Shared UI components and theme system for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist",
    "src/theme"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./theme/theme.css": "./src/theme/theme.css",
    "./theme/tailwind.css": "./src/theme/tailwind.css",
    "./theme/base.css": "./src/theme/theme.base.css",
    "./theme/semantic.css": "./src/theme/semantic.css",
    "./theme/surfaces.css": "./src/theme/surfaces.css",
    "./theme/overflow-fade.css": "./src/theme/overflow-fade.css",
    "./theme/typography.css": "./src/theme/typography.css",
    "./recipes/button": {
      "types": "./dist/recipes/button.d.mts",
      "default": "./dist/recipes/button.mjs"
    },
    "./theme/tokens.js": "./src/theme/tokens.js",
    "./theme/tokens.d.ts": "./src/theme/tokens.d.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "theme:build": "node src/theme/build-state-layers.mjs && cd src/theme && terrazzo build --config terrazzo.config.js && cd ../.. && oxfmt src/theme/tokens.generated.json src/theme/theme.css src/theme/tokens.js",
    "theme:watch": "node src/theme/watch.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/ui/src\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^9.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@terrazzo/cli": "^0.6.0",
    "@terrazzo/plugin-css": "^0.6.0",
    "@terrazzo/plugin-js": "^0.6.0",
    "@types/node": "^20.19.42",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "colorjs.io": "^0.5.2",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^9.0.0",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.22.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "packageManager": "pnpm@10.28.2"
}
