{
  "name": "@emdash/ui",
  "version": "1.0.0",
  "description": "Shared UI components and theme system for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist",
    "src/theme",
    "src/styles"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/style.css"
  ],
  "exports": {
    "./react": {
      "types": "./dist/src/react/index.d.ts",
      "default": "./dist/react.js"
    },
    "./react/primitives": {
      "types": "./dist/src/react/primitives/index.d.ts",
      "default": "./dist/react/primitives.js"
    },
    "./react/components": {
      "types": "./dist/src/react/components/index.d.ts",
      "default": "./dist/react/components.js"
    },
    "./react/patterns": {
      "types": "./dist/src/react/patterns/index.d.ts",
      "default": "./dist/react/patterns.js"
    },
    "./solid": {
      "types": "./dist/src/solid/index.d.ts",
      "default": "./dist/solid.js"
    },
    "./solid/components": {
      "types": "./dist/src/solid/components/index.d.ts",
      "default": "./dist/solid/components.js"
    },
    "./style.css": "./dist/style.css",
    "./styles/sprinkles": {
      "types": "./dist/src/styles/sprinkles.css.d.ts",
      "default": "./dist/styles/sprinkles.js"
    },
    "./styles/recipes/control": {
      "types": "./dist/src/styles/recipes/control.d.ts",
      "default": "./dist/styles/recipes/control.js"
    },
    "./styles/recipes/input": {
      "types": "./dist/src/styles/recipes/input.d.ts",
      "default": "./dist/styles/recipes/input.js"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles/base.css": "./src/styles/theme.base.css",
    "./styles/semantic.css": "./src/styles/semantic.css",
    "./styles/effects.css": "./src/styles/effects.css",
    "./styles/overflow-fade.css": "./src/styles/overflow-fade.css",
    "./styles/typography.css": "./src/styles/typography.css",
    "./theme/tokens.js": "./src/theme/core/tokens.js",
    "./theme/tokens.d.ts": "./src/theme/core/tokens.d.ts",
    "./theme/shiki-themes": "./src/theme/themes/shiki-themes.ts",
    "./theme/manifest": "./src/theme/core/theme-manifest.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite build --config vite.lib.config.ts --watch",
    "build": "vite build --config vite.lib.config.ts",
    "test": "vitest run",
    "theme:build": "tsx src/theme/core/build.ts && oxfmt src/styles/theme.css src/styles/semantic.css src/theme/core/tokens.js",
    "theme:watch": "tsx --watch src/theme/core/build.ts",
    "storybook:react": "storybook dev -p 6006 -c .storybook-react",
    "storybook:solid": "storybook dev -p 6007 -c .storybook-solid",
    "build-storybook:react": "storybook build -c .storybook-react",
    "build-storybook:solid": "storybook build -c .storybook-solid",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/ui/src\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.solid.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-mention": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/suggestion": "^3.26.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.564.0"
  },
  "devDependencies": {
    "@emdash/chat-ui": "workspace:*",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^20.19.42",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "colorjs.io": "^0.5.2",
    "devicon": "^2.17.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "solid-js": "^1.9.13",
    "storybook": "^10.4.6",
    "storybook-solidjs-vite": "10.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vite": "^7.1.11",
    "vite-plugin-dts": "5.0.2",
    "vite-plugin-solid": "2.11.12",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "solid-js": "^1.9.13"
  },
  "packageManager": "pnpm@10.28.2"
}
